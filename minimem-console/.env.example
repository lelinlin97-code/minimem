# ───────────────────────────────────────────
# MiniMem Console — 环境变量配置
# 复制: cp .env.example .env
# ───────────────────────────────────────────

# ── 服务器 ──
# CONSOLE_HOST=127.0.0.1
# CONSOLE_PORT=3080

# ── MiniMem 引擎连接 ──
# MINIMEM_BASE_URL=http://127.0.0.1:6677
# MINIMEM_API_TOKEN=your-minimem-jwt-token

# ── LLM（报告生成等） ──
# MINIMEM_LLM_API_KEY=sk-your-api-key-here
# MINIMEM_LLM_BASE_URL=https://api.openai.com/v1
# MINIMEM_LLM_MODEL=gpt-4o-mini

# ── 数据存储（可选） ──
# CONSOLE_DATA_DIR=~/.minimem-console
