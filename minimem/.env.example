# ───────────────────────────────────────────
# MiniMem — 环境变量配置
# 复制此文件为 .env 并填入实际值
#   cp .env.example .env
# ───────────────────────────────────────────

# ── LLM（必需，支持任意 OpenAI 兼容接口） ──
MINIMEM_LLM_API_KEY=sk-your-api-key-here

# ── Embedding（可选，不填则复用 LLM 配置） ──
# MINIMEM_EMBEDDING_API_KEY=sk-your-embedding-key
# MINIMEM_EMBEDDING_BASE_URL=

# ── Vision（可选，用于图片→文字描述） ──
# MINIMEM_VISION_API_KEY=sk-your-vision-key

# ── JWT Secret（必需，MCP / REST API 认证用） ──
# 生成: openssl rand -hex 32
MINIMEM_JWT_SECRET=replace-with-random-32-bytes-hex

# ── 数据目录（可选，默认 ~/.minimem） ──
# MINIMEM_DATA_DIR=/path/to/data
